# BlitzGuard backend configuration

# Server
BLITZGUARD_PORT=3001
BLITZGUARD_CORS_ORIGIN=http://localhost:3000

# GitHub analyzer
# Leave unset to use unauthenticated public API (60 req/h per IP).
# Set a personal access token to get 5000 req/h.
GITHUB_TOKEN=

# Toggle deterministic mock mode for analyzer + battle.
# When true, analyzer always returns scripted score 92 and battle runs the
# 60s scripted timeline. Useful when GitHub API is rate-limited or offline.
BLITZGUARD_MOCK=false

# Optional: override the deterministic battle seed (number).
BLITZGUARD_BATTLE_SEED=11647949
